   "source": [
    "import pandas as pd\n",
    "df = pd.read_csv('trivia_qa.csv')\n",
    "kong = 0\n",
    "for i in range(len(df)):\n",
    "    if df.iloc[i]['reference_answer']:\n",
    "        continue\n",
    "    else:\n",
    "        kong += 1\n",
    "print(kong)"
   ]
